{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/init.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt|permission_prompt",
        "hooks": [{ "type": "http", "url": "http://localhost:19222/hook" }]
      }
    ],
    "Stop": [
      {
        "hooks": [{ "type": "http", "url": "http://localhost:19222/hook" }]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [{ "type": "http", "url": "http://localhost:19222/hook" }]
      }
    ]
  }
}
